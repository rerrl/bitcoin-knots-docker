# Required environment variables - copy this file to .env and customize

# Data directory paths
BITCOIN_DATA_PATH=./bitcoin-data
ELECTRS_DATA_PATH=./electrs-data
TOR_DATA_PATH=./tor-data

# Electrs configuration
ELECTRS_SERVER_BANNER=electrs 0.10.9

# LND configuration
LND_DATA_PATH=./lnd-data
LIT_DATA_PATH=./lit-data

# LND + Lightning Terminal (enable by uncommenting below)
# COMPOSE_PROFILES=tor,lnd

# User IDs - should match your host system user
USER_ID=1000
GROUP_ID=1000
